{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "setup": "node scripts/setup.mjs",
    "setup:mcp": "node scripts/setup-mcp-vendors.mjs",
    "deployment:start": "node deployment/bootstrap.mjs",
    "deployment:replit": "node deployment/replit.mjs",
    "deployment:manus": "node deployment/manus.mjs",
    "deployment:termux": "bash deployment/termux.sh",
    "dev": "pnpm --filter @workspace/api-server dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:frontend": "pnpm --filter @workspace/command-sim build",
    "build:server": "pnpm --filter @workspace/api-server build",
    "start": "pnpm --filter @workspace/api-server start",
    "rag:sync": "node scripts/rag-sync.mjs",
    "local:setup": "pnpm setup",
    "local:run": "NODE_ENV=production pnpm build && pnpm start",
    "test:strategy": "pnpm --filter @workspace/strategy-sim test",
    "test:assets": "pnpm --filter @workspace/asset-pipeline test",
    "test:command-sim": "pnpm --filter @workspace/command-sim test",
    "test:integration": "pnpm test:strategy && pnpm test:assets && pnpm test:command-sim",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "typescript": "~5.9.3"
  }
}
