# -----------------------------------------------------------------------------
# Asset Generation API
# -----------------------------------------------------------------------------
PUBLIC_BASE_URL=https://game.example.com
ASSET_PIPELINE_ROOT=/persistent/asset-pipeline
ASSET_WORKER_TOKEN=replace-with-at-least-24-random-characters
ASSET_WORKER_TIMEOUT_MS=1800000

# Mandatory post-processing worker
ASSET_BLENDER_WORKER_URL=https://blender-worker.example.com

# Configure only installed provider workers. The API follows each job's
# generatorPreference list and chooses the first configured worker.
ASSET_WORKER_HUNYUAN3D_2_URL=https://hunyuan-worker.example.com
ASSET_WORKER_INSTANTMESH_URL=https://instantmesh-worker.example.com
ASSET_WORKER_TRIPOSR_URL=https://triposr-worker.example.com
# ASSET_WORKER_FLASHVDM_URL=https://flashvdm-worker.example.com
ASSET_WORKER_MPFB2_URL=https://human-worker.example.com
# ASSET_WORKER_MAKEHUMAN_URL=https://makehuman-worker.example.com
# ASSET_WORKER_DECA_URL=https://deca-worker.example.com
# ASSET_WORKER_ECON_URL=https://econ-worker.example.com
ASSET_WORKER_FREEMOCAP_URL=https://mocap-worker.example.com
# ASSET_WORKER_MEDIAPIPE_URL=https://mediapipe-worker.example.com

# -----------------------------------------------------------------------------
# OpenTelemetry / Highlight
# -----------------------------------------------------------------------------
OTEL_SERVICE_NAME=operation-kobenhavn-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://collector.example.com
# Comma-separated key=value pairs. Never commit real credentials.
OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20replace-me
# Alternative endpoint variable when Highlight is the OTLP backend:
# HIGHLIGHT_OTLP_ENDPOINT=https://collector.highlight.io

# Browser build variables
VITE_HIGHLIGHT_PROJECT_ID=
VITE_SESSION_REPLAY_FALLBACK=rrweb

# Self-hosted rrweb fallback
SESSION_REPLAY_ROOT=/persistent/session-replay
SESSION_REPLAY_RETENTION_DAYS=7
OBSERVABILITY_REPLAY_ADMIN_TOKEN=replace-with-a-separate-admin-token

# -----------------------------------------------------------------------------
# Generic asset worker container
# -----------------------------------------------------------------------------
ASSET_WORKER_ROOT=/work
ASSET_COMMAND_TIMEOUT_SECONDS=3600
ASSET_WORKER_MAX_DOWNLOAD_BYTES=1500000000
ASSET_KEEP_WORKDIR=false

# Provider commands are fixed administrator configuration. They are parsed into
# argv and executed with shell=false. Requests cannot replace these commands.
#
# ASSET_WORKDIR_HUNYUAN3D_2=/opt/Hunyuan3D-2
# ASSET_COMMAND_HUNYUAN3D_2=python /opt/wrappers/hunyuan.py --input {input} --output-dir {output_dir} --seed {seed}
# ASSET_GENERATOR_VERSION_HUNYUAN3D_2=2.0
#
# ASSET_WORKDIR_BLENDER=/opt/blender-worker
# ASSET_COMMAND_BLENDER=blender --background --python /opt/wrappers/process_asset.py -- --input-dir {input_dir} --output-dir {output_dir} --target-polygons {target_polygon_count} --lod-count {lod_count} --skeleton {skeleton_id}
# ASSET_GENERATOR_VERSION_BLENDER=4.3
