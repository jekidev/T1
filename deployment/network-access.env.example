# Network retrieval permission boundary
# Generate independent random values. Never expose them through VITE_* variables.

# Required for approving Ask First requests or enabling an application Ultra session.
# Minimum 24 characters. The browser supplies this only in X-Network-Permission-Token.
NETWORK_PERMISSION_ADMIN_TOKEN=replace-with-a-random-secret-at-least-24-characters

# Required for coding-agent repository analysis, run creation, execution and stop.
# Use a different value from NETWORK_PERMISSION_ADMIN_TOKEN.
CODING_AGENT_ADMIN_TOKEN=replace-with-a-separate-random-secret-at-least-24-characters

# API-to-worker authentication. Use another independent value.
CODING_AGENT_WORKER_TOKEN=replace-with-an-independent-worker-secret-at-least-24-characters

# Optional worker endpoints.
# CODING_AGENT_WORKER_URL=https://coding-agent-worker.internal/
# CODING_AGENT_OPENHANDS_URL=https://coding-agent-worker.internal/
# CODING_AGENT_AIDER_URL=https://coding-agent-worker.internal/

# Coding-agent provider models. Browsing-capable models are rejected unless the
# immutable coding-agent run is explicitly configured as Ultra.
# CODING_AGENT_OPENHANDS_MODEL=openrouter/non-browsing-model
# CODING_AGENT_AIDER_MODEL=openrouter/non-browsing-model

# The normal in-game advisor remains non-browsing. Do not configure :online,
# Perplexity/Sonar, search-preview or grounded-search models for advisor routes.
