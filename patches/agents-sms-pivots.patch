+// In-memory SMS status cache for get_sms to avoid hammering provider APIs.
+const smsCache = new Map<string, { result: any; at: number }>();
+const SMS_CACHE_TTL_MS = 5 * 1000; // 5 seconds
+
+function smsCacheKey(providerName: string, numberId: string): string {
+  return `${providerName}:${numberId}`;
+}
+
+// In-memory cache for list_services to avoid repeated provider price lookups.
+const servicesCache = new Map<string, { services: any[]; total: number; at: number }>();
+const SERVICES_CACHE_TTL_MS = 5 * 60 * 1000; // 5 minutes
+
+function servicesCacheKey(country: string, search?: string): string {
+  return `${country}:${search || "*"}`;
+}
+
+// Redact configured API keys from any text before it is returned or logged.
+function getSecretValues(): string[] {
+  const keys = [
+    process.env.FIVESIM_API_KEY,
+    process.env.SMSACTIVATE_API_KEY,
+    process.env.ONLINESIM_API_KEY,
+  ].filter((v): v is string => typeof v === "string" && v.length >= 4);
+  return keys;
+}
+
+function redactSecrets(text: string): string {
+  const secrets = getSecretValues();
+  if (secrets.length === 0) return text;
+  secrets.sort((a, b) => b.length - a.length);
+  let out = text;
+  for (const secret of secrets) {
+    out = out.replaceAll(secret, "[REDACTED]");
+  }
+  return out;
+}
+
+function safeJson(value: unknown): string {
+  return redactSecrets(JSON.stringify(value));
+}
+
+// Wrap stderr writes so fatal and debug logs never leak API keys.
+const originalStderrWrite = process.stderr.write.bind(process.stderr);
+process.stderr.write = (
+  chunk: any,
+  encoding?: any,
+  cb?: any
+) => {
+  const raw = typeof chunk === "string" ? chunk : Buffer.isBuffer(chunk) ? chunk.toString("utf8") : String(chunk);
+  return originalStderrWrite(redactSecrets(raw), encoding, cb);
+};
+
 
