{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "T1 Knowledge Chunk",
  "type": "object",
  "required": [
    "chunk_id",
    "document_sha256",
    "source_name",
    "page",
    "risk_tier",
    "retrieval_default",
    "text"
  ],
  "properties": {
    "chunk_id": {"type": "string"},
    "document_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_name": {"type": "string"},
    "page": {"type": "integer", "minimum": 1},
    "chunk_number": {"type": "integer", "minimum": 1},
    "risk_tier": {"type": "string"},
    "retrieval_default": {"type": "boolean"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "canonical_chunk_id": {"type": "string"},
    "text_sha256": {"type": "string"},
    "text": {"type": "string"}
  }
}
