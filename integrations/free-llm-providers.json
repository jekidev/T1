{
  "policy": {
    "credentialMode": "bring-your-own-key",
    "sharedKeysAllowed": false,
    "embeddedKeysAllowed": false,
    "notes": "Provider directories may be used for discovery, but credentials must be created by the user and stored in a platform secret store."
  },
  "sources": [
    {
      "repository": "open-free-llm-api/awesome-freellm-apis",
      "status": "approved-directory",
      "use": "Provider and model discovery only",
      "automaticCredentialImport": false
    },
    {
      "repository": "alistaitsacle/free-llm-api-keys",
      "status": "blocked-credentials-source",
      "use": "None",
      "automaticCredentialImport": false,
      "reason": "Shared, unknown, or embedded API keys must not be imported into the project."
    }
  ],
  "providers": [
    {"id":"openrouter","name":"OpenRouter","baseUrl":"https://openrouter.ai/api/v1","envKey":"OPENROUTER_API_KEY","enabledByDefault":true,"openAiCompatible":true},
    {"id":"groq","name":"Groq","baseUrl":"https://api.groq.com/openai/v1","envKey":"GROQ_API_KEY","enabledByDefault":false,"openAiCompatible":true},
    {"id":"mistral","name":"Mistral AI","baseUrl":"https://api.mistral.ai/v1","envKey":"MISTRAL_API_KEY","enabledByDefault":false,"openAiCompatible":true},
    {"id":"huggingface","name":"Hugging Face Inference","baseUrl":"https://router.huggingface.co/v1","envKey":"HF_TOKEN","enabledByDefault":false,"openAiCompatible":true},
    {"id":"github-models","name":"GitHub Models","baseUrl":"https://models.inference.ai.azure.com","envKey":"GITHUB_MODELS_TOKEN","enabledByDefault":false,"openAiCompatible":true},
    {"id":"nvidia-nim","name":"NVIDIA NIM","baseUrl":"https://integrate.api.nvidia.com/v1","envKey":"NVIDIA_API_KEY","enabledByDefault":false,"openAiCompatible":true}
  ]
}
