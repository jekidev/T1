{
  "name": "personal-framework-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Mobile-first personal memory and crime fiction writing studio.",
  "scripts": {
    "dev": "../../scripts/dev.sh",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "start": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "validate": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.18.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
