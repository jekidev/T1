NODE_ENV=development
PORT=8080
BASE_PATH=/

# Google Maps is the preferred board underlay. When the key is empty,
# the frontend automatically falls back to OpenStreetMap.
VITE_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# LLM routing modes: rotate | static | off
LLM_ROUTING_MODE=rotate
LLM_STATIC_MODEL=nvidia/nemotron-nano-9b-v2:free

# Default rotation when OPENROUTER_MODELS is empty:
# nvidia/nemotron-nano-9b-v2:free
# google/gemma-4-26b-a4b-it:free
# mistralai/mistral-nemo
OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_MODELS=
OPENROUTER_AUTO_DISCOVER=false
OPENROUTER_FREE_ONLY=true
OPENROUTER_MODEL_LIMIT=30
OPENROUTER_TIMEOUT_MS=45000
OPENROUTER_RETRIES=1
OPENROUTER_COOLDOWN_MS=60000
OPENROUTER_MAX_TOKENS=1400
OPENROUTER_TEMPERATURE=0.6
OPENROUTER_APP_NAME=Urban Strategy Simulator
OPENROUTER_SITE_URL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Hourly everyday-wisdom heads-up.
# HEADS_UP_DEFAULT_MODE controls server-created hourly notifications; the user can
# independently switch Light/Balanced/Uber in the board UI.
WISDOM_RAG_SUBFOLDER=wisdom/common/everyday tips
HEADS_UP_DEFAULT_MODE=balanced
HEADS_UP_INTERVAL_MS=3600000
HEADS_UP_RUN_ON_START=true

# Uber mode creates review-only potential PR scripts, never auto-executes them.
LLM_SCRIPT_OUTPUT_DIR=rag/Code/LLM_scripts
UBER_SCRIPT_INTERVAL_MS=900000
UBER_SOURCE_MAX_CHARS=60000
PYTHON_BIN=python3

# Optional free-provider fallbacks. Bring your own keys only.
GROQ_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
GITHUB_MODELS_TOKEN=

# MCP connections. Keep secrets in Replit/Manus/platform secret stores.
MCP_FILESYSTEM_ROOTS=features,integrations,plugins,ai-workspace,rag
GITHUB_MCP_TOKEN=
HF_TOKEN=

# Telegram auth service + Telegram MCP (chigwell/telegram-mcp and jekidev/telegram-mcp-1).
TELEGRAM_AUTH_API_URL=http://127.0.0.1:8090
TELEGRAM_AUTH_API_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
# User requested modify support. Every modifying tool still requires explicit approval.
TELEGRAM_EXPOSED_TOOLS=all
# telegram-mcp-1 can use a file-based session name instead of a session string.
# TELEGRAM_SESSION_NAME=telegram_session
# Optional proxy for telegram-mcp-1: socks5, socks4, http, or mtproxy.
# TELEGRAM_PROXY_TYPE=
# TELEGRAM_PROXY_HOST=
# TELEGRAM_PROXY_PORT=
# TELEGRAM_PROXY_USERNAME=
# TELEGRAM_PROXY_PASSWORD=

RSSHUB_BASE_URL=https://rsshub.app

# 5sim SMS API (via agents-sms MCP vendor). At least one provider key is required.
FIVESIM_API_KEY=
# SMSACTIVATE_API_KEY=
# ONLINESIM_API_KEY=

# Signal CLI MCP (via signal-cli-rest-api). Set your Signal number and optional settings.
SIGNAL_ACCOUNT=
SIGNAL_CLI_BASE_URL=http://localhost:8080
SIGNAL_APPROVAL_TIMEOUT_MS=600000
SIGNAL_GUI_PORT=8088
# SIGNAL_NTFY_TOPIC=
# SIGNAL_NTFY_BASE_URL=https://ntfy.sh
# SIGNAL_GUI_PUBLIC_URL=

DATABASE_URL=

# Local folder containing files downloaded or synced from Google Drive.
# Termux example:
# GOOGLE_DRIVE_RAG_PATH=/data/data/com.termux/files/home/storage/shared/GoogleDriveRAG
GOOGLE_DRIVE_RAG_PATH=rag/google-drive
