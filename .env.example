# Runtime
NODE_ENV=development
PORT=8080
BASE_PATH=/

# LLM provider
OPENROUTER_API_KEY=

# Optional database
DATABASE_URL=

# RAG input folders. Separate multiple paths with ':' on Linux/Android/macOS
# and ';' on Windows.
# Example for Termux:
# RAG_SOURCE_PATHS=/data/data/com.termux/files/home/storage/shared/GoogleDriveRAG:/data/data/com.termux/files/home/storage/shared/ProtonDriveRAG
RAG_SOURCE_PATHS=
RAG_INBOX_DIR=rag/inbox
