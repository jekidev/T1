NODE_ENV=development
PORT=8080
BASE_PATH=/

# OpenRouter resilience
# Use OPENROUTER_API_KEYS for comma-separated key rotation. OPENROUTER_API_KEY remains supported.
OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
# Optional fixed model list. Leave empty to discover models automatically.
OPENROUTER_MODELS=
OPENROUTER_FREE_ONLY=true
OPENROUTER_MODEL_LIMIT=30
OPENROUTER_TIMEOUT_MS=45000
OPENROUTER_RETRIES=1
OPENROUTER_COOLDOWN_MS=60000
OPENROUTER_MAX_TOKENS=1400
OPENROUTER_TEMPERATURE=0.6
OPENROUTER_APP_NAME=Urban Strategy Simulator
OPENROUTER_SITE_URL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

DATABASE_URL=

# Local folder containing files downloaded or synced from Google Drive.
# Termux example:
# GOOGLE_DRIVE_RAG_PATH=/data/data/com.termux/files/home/storage/shared/GoogleDriveRAG
GOOGLE_DRIVE_RAG_PATH=rag/google-drive
